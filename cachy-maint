#!/bin/bash
# 1. Start Sudo safely BEFORE any logging starts
sudo -v || exit 1

# 2. Setup Log
REAL_USER=$(logname)
LOG_DIR="/home/$REAL_USER/.local/share/cachy-maint/logs"
mkdir -p "$LOG_DIR"
TMPLOG="/tmp/cachy-maint.log"
sudo rm -f "$TMPLOG"
TS=$(date +%Y-%m-%d_%H%M)

# 3. Run the Workhorse through Sudo and Log it
# We use sudo -E to keep the user environment for Topgrade
sudo -E bash -c "/usr/bin/cachy-maint-work" 2>&1 | perl -pe 's/\e\[?.*?[\x40-\x7e]//g; s/\e\(B//g' > "$TMPLOG"

EXIT_CODE=${PIPESTATUS[0]}

# 4. Handle Result & Summary
if [ "$EXIT_CODE" -eq 0 ]; then
    rm -f "$TMPLOG"
    MSG="\e[1;32m[‚úî] SUCCESS: System is up to date.\e[0m"
else
    sudo chown $REAL_USER:$REAL_USER "$TMPLOG"
    mv "$TMPLOG" "$LOG_DIR/cachy-maint_ERROR_$TS.log"
    MSG="\e[1;31m[!] ERROR: Log saved to $LOG_DIR/cachy-maint_ERROR_$TS.log\e[0m"
fi

printf "\n\e[1;33m‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ\e[0m\n %b\n Finished at: %s\n\e[1;33m‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ\e[0m\n" "$MSG" "$(date)"

if (( SHLVL < 2 )); then
    read -p "Press ENTER to close..." dummy
fi
