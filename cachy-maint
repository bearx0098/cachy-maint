#!/bin/bash

# 1. Ask for sudo password once at the start.
# This ensures the rest of the script doesn't get stuck.
sudo -v

# 2. Keep the sudo timestamp alive in the background while script runs
while true; do sudo -n true; sleep 60; kill -0 "$$" || exit; done 2>/dev/null &

# 3. Setup Folders
# We use /home/bearx explicitly because $HOME can change to /root if run with sudo
REAL_USER=$(logname)
LOG_DIR="/home/$REAL_USER/.local/share/cachy-maint/logs"
mkdir -p "$LOG_DIR"
TMPLOG="/tmp/cachy-maint.log"
sudo rm -f "$TMPLOG" # Clear any old root-owned logs
TS=$(date +%Y-%m-%d_%H%M)

# 4. Ensure dependencies are installed
DEPENDENCIES=(expect perl topgrade paru)
for cmd in "${DEPENDENCIES[@]}"; do
    if ! command -v "$cmd" &> /dev/null; then
        echo "Installing missing dependency: $cmd..."
        sudo pacman -S --noconfirm "$cmd" || paru -S --noconfirm "$cmd"
    fi
done

# 5. Run Maintenance as USER (allows Topgrade to work correctly)
(
    unbuffer sudo rm -rf /var/cache/pacman/pkg/download-* && \
    unbuffer sudo paccache -r && \
    unbuffer paru -Scc --noconfirm --cleanafter && \
    paru -Qdtq | xargs -r unbuffer sudo pacman -Rns --noconfirm && \
    DBUS_SESSION_BUS_ADDRESS=/dev/null unbuffer topgrade -y
) 2>&1 | tee >(perl -pe 's/\e\[?.*?[\x40-\x7e]//g; s/\e\(B//g' > "$TMPLOG")

EXIT_CODE=${PIPESTATUS[0]}
sleep 1

# 6. Handle Logs
if [ "$EXIT_CODE" -eq 0 ]; then
    rm -f "$TMPLOG"
    MSG="\e[1;32m[✔] SUCCESS: System is up to date.\e[0m"
else
    # Ensure the log file is owned by the user so it can be moved
    sudo chown $REAL_USER:$REAL_USER "$TMPLOG"
    mv "$TMPLOG" "$LOG_DIR/cachy-maint_ERROR_$TS.log"
    MSG="\e[1;31m[!] ERROR: Log saved to $LOG_DIR/cachy-maint_ERROR_$TS.log\e[0m"
fi

# 7. Summary
printf "\n\e[1;33m──────────────────────────────────────────────────\e[0m\n %b\n Finished at: %s\n\e[1;33m──────────────────────────────────────────────────\e[0m\n" "$MSG" "$(date)"

if (( SHLVL < 2 )); then
    read -p "Press ENTER to close..." dummy
fi
